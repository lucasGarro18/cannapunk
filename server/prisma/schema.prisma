generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  username       String    @unique
  passwordHash   String
  avatar         String?
  bio            String?
  roles          String    @default("buyer")
  onboardingDone Boolean   @default(false)
  payoutCbu          String?
  payoutMp           String?
  payoutUsdt         String?
  resetToken         String?
  resetTokenExpiry   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  listings       Product[]        @relation("seller")
  orders         Order[]          @relation("buyer")
  videos         Video[]
  commissions    Commission[]
  withdrawals    Withdrawal[]
  reviews        Review[]
  following      Follow[]         @relation("follower")
  followers      Follow[]         @relation("following")
  notifications  Notification[]
  deliveries     Order[]          @relation("delivery")
  conversations  ConversationParticipant[]
  sentMessages   Message[]        @relation("sentMessages")
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String
  price         Int
  originalPrice Int?
  category      String
  imageUrl      String
  commissionPct Int      @default(8)
  stock         Int      @default(0)
  status        String   @default("active")
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  videoCount    Int      @default(0)
  salesCount    Int      @default(0)
  createdAt     DateTime @default(now())

  seller        User         @relation("seller", fields: [sellerId], references: [id])
  sellerId      String

  orderItems    OrderItem[]
  videos        Video[]
  reviews       Review[]
}

model Order {
  id          String   @id @default(cuid())
  status      String   @default("processing")
  total       Int
  address     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buyer       User     @relation("buyer",    fields: [buyerId],    references: [id])
  buyerId     String
  deliverer   User?    @relation("delivery", fields: [delivererId], references: [id])
  delivererId String?
  referrer    Video?   @relation(fields: [referrerId], references: [id])
  referrerId  String?

  items       OrderItem[]
  commissions Commission[]
  reviews     Review[]
}

model OrderItem {
  id        String  @id @default(cuid())
  qty       Int
  unitPrice Int

  order     Order   @relation(fields: [orderId],   references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
}

model Video {
  id            String   @id @default(cuid())
  title         String
  description   String?
  thumbnailUrl  String?
  videoUrl      String?
  likes         Int      @default(0)
  views         Int      @default(0)
  commissionPct Int      @default(0)
  tags          String   @default("[]")
  createdAt     DateTime @default(now())

  creator      User     @relation(fields: [creatorId], references: [id])
  creatorId    String
  product      Product? @relation(fields: [productId],  references: [id])
  productId    String?

  commissions    Commission[]
  referredOrders Order[]
}

model Commission {
  id        String   @id @default(cuid())
  amount    Int
  status    String   @default("pending")
  createdAt DateTime @default(now())

  creator   User    @relation(fields: [creatorId], references: [id])
  creatorId String
  video     Video   @relation(fields: [videoId],   references: [id])
  videoId   String
  order     Order   @relation(fields: [orderId],   references: [id])
  orderId   String
}

model Follow {
  follower    User     @relation("follower",  fields: [followerId],  references: [id])
  followerId  String
  following   User     @relation("following", fields: [followingId], references: [id])
  followingId String
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  user           User         @relation(fields: [userId],          references: [id])
  userId         String
  lastReadAt     DateTime?

  @@id([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  sender         User         @relation("sentMessages", fields: [senderId], references: [id])
  senderId       String
}

model PendingOrder {
  id         String   @id @default(cuid())
  mpPrefId   String   @unique
  buyerId    String
  items      String
  address    String
  referrerId String?
  total      Int
  createdAt  DateTime @default(now())
}

model Withdrawal {
  id        String   @id @default(cuid())
  amount    Int
  method    String
  reference String?
  status    String   @default("pending")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  userId    String
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  userId    String
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  body      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId],    references: [id])
  userId    String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  order     Order    @relation(fields: [orderId],   references: [id])
  orderId   String

  @@unique([userId, productId])
}
