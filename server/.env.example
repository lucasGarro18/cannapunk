DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/cannapont"
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-random"
JWT_EXPIRES_IN="7d"
PORT=4000
CLIENT_URL="http://localhost:5173"
BASE_URL="http://localhost:4000"

# ─── MercadoPago ────────────────────────────────────────────────
# TEST-xxxx para sandbox, APP_USR-xxxx para producción
MP_ACCESS_TOKEN="TEST-xxxx"
FRONTEND_URL="http://localhost:5173"
# En Railway: URL pública del backend (ej: https://cannapont-api.up.railway.app)
API_URL="http://localhost:4000"

# ─── Email transaccional ────────────────────────────────────────
# Funciona con Gmail, Brevo, Resend SMTP, etc.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu@gmail.com"
SMTP_PASS="app-password-de-gmail"
SMTP_FROM="Cannapont <noreply@cannapont.com>"

# ─── Cloud Storage — Cloudflare R2 ─────────────────────────────
# Si estas variables están presentes, los uploads van a R2.
# Si no están, se usa /uploads local (solo para desarrollo).
# Guía: https://developers.cloudflare.com/r2/get-started/
R2_ACCOUNT_ID="tu-account-id-de-cloudflare"
R2_ACCESS_KEY_ID="tu-r2-access-key-id"
R2_SECRET_ACCESS_KEY="tu-r2-secret-access-key"
R2_BUCKET_NAME="cannapont-media"
# URL pública del bucket (dominio custom o URL pública R2)
R2_PUBLIC_URL="https://media.cannapont.com"

# ─── Modelo de negocio ─────────────────────────────────────────
# Porcentaje que retiene la plataforma de cada comisión (0.08 = 8%)
# Si no se setea, el creador recibe el 100% de la comisión
PLATFORM_FEE=0.08

# ─── Web Push / VAPID ───────────────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
VAPID_EMAIL="admin@cannapont.com"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
